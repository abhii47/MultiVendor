{
  "name": "multivendor",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "node dist/seeders/seed.js",
    "dev": "cross-env NODE_ENV=development npm run db:migrate:dev && npm run seed && npm run start",
    "docker": "cross-env NODE_ENV=production sh -c \"npm run db:migrate:prod && npm run seed && node dist/server.js\"",
    "db:migrate:dev": "sequelize-cli db:migrate --env development --config dist/config/sequelizeCliConfig.js --migrations-path dist/migrations",
    "db:migrate:undo:dev": "sequelize-cli db:migrate:undo --env development --config dist/config/sequelizeCliConfig.js --migrations-path dist/migrations",
    "db:migrate:prod": "sequelize-cli db:migrate --env production --config dist/config/sequelizeCliConfig.js --migrations-path dist/migrations",
    "db:migrate:undo:prod": "sequelize-cli db:migrate:undo --env production --config dist/config/sequelizeCliConfig.js --migrations-path dist/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^8.0.0",
    "sequelize-cli": "^6.6.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@aws-sdk/s3-request-presigner": "^3.967.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.5",
    "cookie-parser": "^1.4.7",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.18.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "sequelize": "^6.37.7",
    "stripe": "^20.4.1",
    "winston": "^3.19.0",
    "winston-cloudwatch": "^6.3.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
